# Coinbase Advanced Trade (CDP API) — required for live scalp when [scalp] venue = "coinbase_perps"
# COINBASE_API_KEY = full resource name: organizations/<org>/apiKeys/<id>
# COINBASE_API_SECRET = ECDSA PEM (multiline or one line with literal \n between PEM lines)
COINBASE_API_KEY=
COINBASE_API_SECRET=
# Optional second CDP key pair (recommended when slot 1 is revoked / mismatched PEM):
COINBASE_API_KEY2=
COINBASE_API_SECRET2=
# Use secondary pair everywhere (live REST, bar_store backfill): COINBASE_CDP_CREDENTIAL_SLOT=2
# Same keys are used by bar_store Coinbase candle backfill (optional but recommended for rate limits):
#   python .optimization/pnl-feedback-lab/scripts/backfill_coinbase_lab_intervals.py

# Dashboard security (NM-008): set a random token to restrict non-loopback WebSocket access.
# Only needed when config.toml host = "0.0.0.0" (remote dashboard access).
# With host = "127.0.0.1" (default), loopback connections bypass the token check automatically.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DASHBOARD_TOKEN=

# Optional safety: force paper / strip keys (see README)
# ARCEUS_SAFE_STARTUP=1
# ARCEUS_DISABLE_LIVE_KEYS=1

# Kraken — only if you use legacy Kraken tooling elsewhere (not used by Coinbase scalp in main.py)
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=
