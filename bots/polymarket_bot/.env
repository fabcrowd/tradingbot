PMBOT_BOT_ID=polymarket_bot
PMBOT_DISPLAY_NAME=Polymarket Bot
PMBOT_VERSION=0.1.0
PMBOT_ENV=dev
PMBOT_HOST=0.0.0.0
PMBOT_PORT=8091

# paper | live
PMBOT_MODE=paper
PMBOT_CYCLE_MS=1000
PMBOT_USE_PUBLIC_POLYMARKET_FEED=true
PMBOT_GAMMA_API_URL=https://gamma-api.polymarket.com
PMBOT_MARKET_QUERY=5-minute 15-minute
PMBOT_PREFERRED_SYMBOLS=BTC,ETH
PMBOT_LIVE_DRY_RUN=true

# position sizing
PMBOT_QUOTE_SIZE_USD=5.0
PMBOT_MAX_CONCURRENT_POSITIONS=10
PMBOT_PER_MARKET_MAX_POSITIONS=3

# signal thresholds
PMBOT_TAKER_MIN_MOMENTUM_PCT=0.3
PMBOT_TAKER_MIN_NET_EDGE_BPS=20

# risk defaults
PMBOT_DAILY_LOSS_LIMIT_USD=20
PMBOT_MAX_POSITION_PCT=0.5
PMBOT_MAX_PORTFOLIO_EXPOSURE_USD=200

# WebSocket endpoints (override for testing)
# PMBOT_RTDS_URL=wss://ws-live-data.polymarket.com
# PMBOT_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# live trading credentials (only required when PMBOT_MODE=live)
PMBOT_POLY_PRIVATE_KEY=
PMBOT_POLY_FUNDER=
PMBOT_POLY_API_KEY=
PMBOT_POLY_API_SECRET=
PMBOT_POLY_API_PASSPHRASE=
PMBOT_POLY_CLOB_HOST=https://clob.polymarket.com
PMBOT_POLY_CHAIN_ID=137
PMBOT_POLY_SIGNATURE_TYPE=1

# ── Strategy Router ──
PMBOT_SPORTS_ALLOC_PCT=50
PMBOT_MAKER_ALLOC_PCT=30
PMBOT_CRYPTO_ALLOC_PCT=20

# ── Sports Odds Arb ──
PMBOT_ODDS_API_KEY=317b9d56fda1853313b5f7201c5180f2cb3a2a4ca0dec1ed69f574957b197aa1
PMBOT_THE_ODDS_API_KEYS=893bb9ae10ce419ff89a8d15cdaa4d53,4ceee6f78cc2425e9caa904766116ca5,d5bffa1b2b94fd1250bd118f71936405,172a9504d80e30a60c9eb0056fda5449
PMBOT_SPORTS_MIN_EDGE_BPS=50
PMBOT_SPORTS_POLL_SEC=30
PMBOT_SPORTS_COOLDOWN_SEC=30

# ── Maker Spread Capture ──
PMBOT_MAKER_MIN_SPREAD_PCT=2.0
PMBOT_MAKER_MIN_VOLUME_USD=10000
PMBOT_MAKER_SCAN_ALL_CATEGORIES=true

# ── Crypto Taker (schedule-aware) ──
